# Crypto Bot Configuration
BOT_MODE=paper_trading  # Options: paper_trading, live_trading
LOG_LEVEL=INFO
DEBUG=False

# Exchange Configuration
PRIMARY_EXCHANGE=binance  # For paper trading
LIVE_EXCHANGE=binance  # For real trading with Binance.US

# Binance.US API Keys (only needed for live trading)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Coinbase API Keys (optional, for future use)
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret
COINBASE_PASSPHRASE=your_coinbase_passphrase

# Trading Configuration
INITIAL_BALANCE=10000  # Starting balance for paper trading
TARGET_CRYPTO=BTC/USDT  # Main trading pair
TRADE_AMOUNT=0.01  # Amount per trade
MAX_OPEN_POSITIONS=3

# Model Configuration
MODEL_TYPE=lstm  # Options: lstm, simple_ma, random_forest
PREDICTION_HORIZON=24  # hours ahead to predict
