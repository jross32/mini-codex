# Shared environment configuration
VITE_API_BASE_URL=http://localhost:5000/api

# Backend settings
FLASK_ENV=development
API_HOST=127.0.0.1
API_PORT=5000
SECRET_KEY=replace-me

# Database URL (defaults to SQLite in dev if not set)
# For local development (SQLite - automatic):
DATABASE_URL=sqlite:///./backend/app.db
# For PostgreSQL (uncomment and update for production):
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/app_db
